# API URL for Laravel Backend
VITE_API_URL=https://your-laravel-api.com/api

# Configuration Cloudflare R2 pour l'upload d'images
# Récupérez ces valeurs depuis votre tableau de bord Cloudflare R2

# Votre Account ID Cloudflare (visible dans le dashboard R2)
VITE_R2_ACCOUNT_ID=your-account-id

# Access Key ID (généré dans R2 -> Manage R2 API Tokens)
VITE_R2_ACCESS_KEY_ID=your-access-key-id

# Secret Access Key (généré avec l'Access Key ID)
VITE_R2_SECRET_ACCESS_KEY=your-secret-access-key

# Nom de votre bucket R2
VITE_R2_BUCKET_NAME=your-bucket-name

# URL publique de votre bucket (format: https://your-bucket-name.your-account-id.r2.cloudflarestorage.com)
VITE_R2_PUBLIC_URL=https://your-bucket-name.your-account-id.r2.cloudflarestorage.com
